rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Authenticated users can listen to their own notifications in real-time
    match /notifications/{docId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // All other collections: block direct client access; all writes go through Cloud Functions (Admin SDK)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
