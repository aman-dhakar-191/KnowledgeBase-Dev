# Cloud Functions URL — only needed for LOCAL development with the Firebase Emulator.
#
# PRODUCTION: When the app is deployed to Firebase Hosting the /api/** rewrite in
#             firebase.json automatically routes requests to the Cloud Function, so
#             you do NOT need to set this variable for production builds.
#
# LOCAL DEV:  Copy this file to .env.local, then fill in your Firebase project ID.
#             Start the emulator with: firebase emulators:start
#
# After running `firebase deploy --only functions` you can also find the function URL in
# the deploy output, e.g.:
#   Function URL (api): https://us-central1-<project-id>.cloudfunctions.net/api
# You can set that URL here if you want the local frontend to talk to the live function.

# For local emulator (replace <your-project-id>):
# VITE_FUNCTIONS_URL=http://127.0.0.1:5001/<your-project-id>/us-central1/api

# For live function (optional, not required for Firebase Hosting deployments):
# VITE_FUNCTIONS_URL=https://us-central1-<your-project-id>.cloudfunctions.net/api
